<div class="page" id="pg-ai"><div class="sh"><h2>AI Staff</h2><span style="color:#8888aa;font-size:0.78rem">9 Agents</span></div><div class="sg" id="sgrid"></div><div class="cb" id="cbox" style="display:none"><div class="ch"><div class="se" id="cav2" style="width:32px;height:32px;font-size:0.9rem;border-radius:50%;display:flex;align-items:center;justify-content:center;"></div><div><strong id="cname"></strong><div style="font-size:0.72rem;color:#8888aa" id="crole"></div></div></div><div class="cm" id="cmsg"></div><div class="ci"><input id="cinp" placeholder="Ask anything..." onkeypress="if(event.key==='Enter')send()"><button class="sendbtn" onclick="send()"><svg viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2.5" width="14" height="14"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg></button></div></div></div>
<div class="page" id="pg-deals"><div class="sh"><h2>Deal Board</h2><button class="sbtn" onclick="openDeal()">+ Post Deal</button></div><div class="dt"><button class="dtb on" onclick="filt('',this)">All</button><button class="dtb" onclick="filt('Partnership',this)">Partnership</button><button class="dtb" onclick="filt('Investment',this)">Investment</button><button class="dtb" onclick="filt('Acquisition',this)">Acquisition</button><button class="dtb" onclick="filt('Franchise',this)">Franchise</button></div><div id="deals"></div></div>
<div class="page" id="pg-net"><div class="sh"><h2>Network</h2></div><div id="netlist"></div></div>
<div class="page" id="pg-msg"><div class="sh"><h2>Messages</h2></div><div class="es"><div style="font-size:2rem">💬</div><p>Connect with businesses to start messaging</p></div></div>
<div class="page" id="pg-profile"><div class="ph2"><div class="pa2" id="pav">?</div><h2 id="pname">Your Business</h2><p style="color:#8888aa;font-size:0.82rem;margin-top:4px" id="pind"></p><div class="ps"><div class="pst"><strong id="pposts">0</strong><span>Posts</span></div><div class="pst"><strong id="pfol">0</strong><span>Followers</span></div><div class="pst"><strong id="pfolg">0</strong><span>Following</span></div></div></div><div class="card"><h3 style="margin-bottom:14px;font-size:0.92rem">Upgrade Plan</h3><div class="pg"><div class="pc2"><h3>Starter</h3><div class="pp">$29<span>/mo</span></div><div class="pf">3 Agents<br>1 Site<br>50 Tasks</div><button class="pb" onclick="sub('price_1TQXFo157b9rpvGCQ0YPsDXn')">Select</button></div><div class="pc2 feat"><h3>Pro</h3><div class="pp" style="background:linear-gradient(135deg,#00e5ff,#9f6bff);-webkit-background-clip:text;-webkit-text-fill-color:transparent">$99<span>/mo</span></div><div class="pf">6 Agents<br>3 Sites<br>200 Tasks</div><button class="pb" onclick="sub('price_1TQXHP157b9rpvGCRw3hzvl2')">Select</button></div><div class="pc2"><h3>Enterprise</h3><div class="pp">$199<span>/mo</span></div><div class="pf">All 9<br>Unlimited<br>Everything</div><button class="pb" onclick="sub('price_1TQXJ3157b9rpvGCQBvDKye0')">Select</button></div></div></div><button style="width:100%;padding:12px;background:rgba(255,45,120,0.15);color:#ff2d78;border:1px solid #ff2d78;border-radius:10px;cursor:pointer;font-weight:700;margin-top:8px" onclick="logout()">Sign Out</button></div>
