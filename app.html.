<!DOCTYPE html>

<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>BizForce AI</title>
<style>*{margin:0;padding:0;box-sizing:border-box}body{background:#030308;color:#e8e8ff;font-family:system-ui;display:flex;align-items:center;justify-content:center;min-height:100vh;flex-direction:column;}.build{color:#00e5ff;text-align:center;font-size:18px;font-weight:bold;margin-bottom:20px;}.box{background:#080812;border:1px solid rgba(0,229,255,0.2);border-radius:20px;padding:40px;width:90%;max-width:400px}h1{background:linear-gradient(135deg,#00e5ff,#9f6bff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;text-align:center;font-size:1.8rem;margin-bottom:6px}p{color:#8888aa;text-align:center;font-size:0.85rem;margin-bottom:24px}.tabs{display:flex;background:rgba(255,255,255,0.05);border-radius:10px;padding:3px;margin-bottom:20px}.tab{flex:1;padding:9px;border:none;background:transparent;color:#8888aa;cursor:pointer;border-radius:8px;font-size:0.9rem}.tab.active{background:linear-gradient(135deg,#00e5ff,#9f6bff);color:#000;font-weight:700}label{display:block;color:#8888aa;font-size:0.75rem;text-transform:uppercase;margin-bottom:5px;margin-top:14px}input{width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(0,229,255,0.15);border-radius:8px;padding:11px 13px;color:#e8e8ff;font-size:0.9rem;outline:none}button.go{width:100%;margin-top:18px;padding:13px;background:linear-gradient(135deg,#00e5ff,#9f6bff);border:none;border-radius:10px;color:#000;font-weight:800;font-size:1rem;cursor:pointer;}.status{color:#00e5ff;font-size:1rem;text-align:center;margin-top:12px;font-weight:600;min-height:24px;}.err{color:#ff2d78;font-size:0.9rem;text-align:center;margin-top:8px;min-height:20px;}</style>
</head>
<body>
<div class="build">BUILD 7 ACTIVE</div>
<div class="box">
<h1>BizForce AI</h1>
<p>Your AI-powered business network</p>
<div class="tabs">
<button class="tab active" type="button" onclick="showLogin()">Sign In</button>
<button class="tab" type="button" onclick="showRegister()">Create Account</button>
</div>
<div id="loginForm">
<label>Email</label>
<input id="le" type="email" placeholder="you@business.com">
<label>Password</label>
<input id="lp" type="password" placeholder="••••••••">
<button class="go" type="button" onclick="alert('LOGIN BUTTON CLICKED');doLogin();">Sign In</button>
</div>
<div id="registerForm" style="display:none">
<label>Business Name</label>
<input id="rb" type="text" placeholder="Your Business Name">
<label>Email</label>
<input id="re" type="email" placeholder="you@business.com">
<label>Password</label>
<input id="rp" type="password" placeholder="Min 8 characters">
<button class="go" type="button" onclick="alert('REGISTER BUTTON CLICKED');doRegister();">Create Account</button>
</div>
<div class="status" id="status">Ready</div>
<div class="err" id="err"></div>
</div>
<script>
var API='https://dynamic-prosperity-production-5382.up.railway.app';
function setStatus(msg){document.getElementById('status').textContent=msg;}
function setErr(msg){document.getElementById('err').textContent=msg;}
function showLogin(){document.getElementById('loginForm').style.display='block';document.getElementById('registerForm').style.display='none';}
function showRegister(){document.getElementById('loginForm').style.display='none';document.getElementById('registerForm').style.display='block';}
async function doLogin() {
  setErr("");
  setStatus("Signing in...");

  const email = document.getElementById("le").value.trim();
  const password = document.getElementById("lp").value.trim();

  if (!email || !password) {
    setStatus("");
    setErr("Enter email and password.");
    return;
  }

  try {
    const response = await fetch(API + "/api/auth/login", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        email: email,
        password: password
      })
    });

    const data = await response.json();

    if (!response.ok) {
      setStatus("");
      setErr(data.error || "Login failed.");
      return;
    }

    localStorage.setItem("bf_token", data.token || "");

    setStatus("Success...");
    window.location.href = "/dashboard.html";
  } catch (error) {
    setStatus("");
    setErr("Connection failed.");
  }
}

async function doRegister() {
  setErr("");
  setStatus("Creating account...");

  const business = document.getElementById("rb").value.trim();
  const email = document.getElementById("re").value.trim();
  const password = document.getElementById("rp").value.trim();

  if (!business || !email || !password) {
    setStatus("");
    setErr("Complete all fields.");
    return;
  }

  try {
    const response = await fetch(API + "/api/auth/register", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        business_name: business,
        email: email,
        password: password
      })
    });

    const data = await response.json();

    if (!response.ok) {
      setStatus("");
      setErr(data.error || "Registration failed.");
      return;
    }

    localStorage.setItem("bf_token", data.token || "");

    setStatus("Success...");
    window.location.href = "/dashboard.html";
  } catch (error) {
    setStatus("");
    setErr("Connection failed.");
  }
}
if(localStorage.getItem('bf_token')){window.location.href='/dashboard.html';}
</script>
</body>
</html>
