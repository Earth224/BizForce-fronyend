<nav class="bottomnav"><button class="nb on" onclick="go('feed')" id="nb-feed"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"></path></svg>Feed</button><button class="nb" onclick="go('net')" id="nb-net"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 00-3-3.87"></path><path d="M16 3.13a4 4 0 010 7.75"></path></svg>Network</button><button class="nb" onclick="go('ai')" id="nb-ai"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="M9 9h6M9 12h6M9 15h4"></path></svg>AI Staff</button><button class="nb" onclick="go('deals')" id="nb-deals"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>Deals</button><button class="nb" onclick="go('profile')" id="nb-profile"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>Profile</button></nav>
<div class="toast" id="toast"></div>
<div class="ov" id="dealov"><div class="mod"><h3>Post a Deal</h3><label>Title</label><input id="dtitle" placeholder="e.g. Looking for distribution partner"><label>Type</label><select id="dtype"><option>Partnership</option><option>Investment</option><option>Acquisition</option><option>Joint Venture</option><option>Franchise</option></select><label>Description</label><textarea id="ddesc" placeholder="Describe the opportunity..." style="min-height:80px"></textarea><div class="ma"><button class="cnc" onclick="closeDeal()">Cancel</button><button class="sbtn" onclick="postDeal()">Post</button></div></div></div>
<script>
const API='https://dynamic-prosperity-production-5382.up.railway.app';
let T=localStorage.getItem('bf_token');
let U=JSON.parse(localStorage.getItem('bf_user')||'null');
let CA=null,CH=[],DF='';
if(!T||!U){window.location.href='/';}
const STAFF=[{id:'alex',name:'Alex',role:'SEO',e:'🔍',c:'#00e5ff'},{id:'jordan',name:'Jordan',role:'Community',e:'👥',c:'#9f6bff'},{id:'morgan',name:'Morgan',role:'Content',e:'✍️',c:'#ff2d78'},{id:'casey',name:'Casey',role:'Email',e:'📧',c:'#ffc800'},{id:'riley',name:'Riley',role:'Sales',e:'💰',c:'#00ff96'},{id:'sam',name:'Sam',role:'Reputation',e:'⭐',c:'#ff6b35'},{id:'dana',name:'Dana',role:'Analytics',e:'📊',c:'#00e5ff'},{id:'taylor',name:'Taylor',role:'Ads',e:'📢',c:'#9f6bff'},{id:'blake',name:'Blake',role:'Influencer',e:'🌟',c:'#ff2d78'}];
function init(){if(!U)return;const i=(U.business_name||U.email||'?')[0].toUpperCase();document.getElementById('tav').textContent=i;document.getElementById('cav').textContent=i;document.getElementById('pav').textContent=i;document.getElementById('pname').textContent=U.business_name||'Your Business';document.getElementById('pind').textContent=U.industry||'';loadFeed();buildStaff();loadDeals();loadNet();}
function go(p){document.querySelectorAll('.page').forEach(x=>x.classList.remove('on'));document.querySelectorAll('.nb').forEach(x=>x.classList.remove('on'));document.getElementById('pg-'+p).classList.add('on');document.getElementById('nb-'+p).classList.add('on');if(p==='profile')loadProfile();}
async function loadFeed(){try{const r=await fetch(API+'/api/feed',{headers:{Authorization:'Bearer '+T}});const d=await r.json();const el=document.getElementById('feed');if(!d.length){el.innerHTML='<div class="es"><div style="font-size:2rem">🌐</div><p>No posts yet. Be the first!</p></div>';return;}el.innerHTML=d.map(p=>`<div class="post"><div class="ph"><div class="av" style="width:32px;height:32px;font-size:0.78rem;flex-shrink:0">${(p.users&&p.users.business_name||'?')[0].toUpperCase()}</div><div class="pm"><strong>${p.users&&p.users.business_name||'Business'}</strong><span>${p.users&&p.users.industry||''} · ${ago(p.created_at)}</span></div></div><div class="pc">${p.content}</div><div class="pa"><button class="pab" onclick="toast('Coming soon!')">👍 Like</button><button class="pab" onclick="toast('Coming soon!')">💬 Comment</button></div></div>`).join('');}catch(e){document.getElementById('feed').innerHTML='<div class="es"><p>Could not load feed</p></div>';}}
async function mkPost(){const c=document.getElementById('ptxt').value.trim();if(!c)return;try{const r=await fetch(API+'/api/posts',{method:'POST',headers:{Authorization:'Bearer '+T,'Content-Type':'application/json'},body:JSON.stringify({content:c})});if(r.ok){document.getElementById('ptxt').value='';toast('Posted!');loadFeed();}}catch(e){toast('Error');}}
function buildStaff(){document.getElementById('sgrid').innerHTML=STAFF.map(s=>`<div class="sc" onclick="pick('${s.id}')" id="sc-${s.id}"><div class="se" style="background:${s.c}22;color:${s.c}">${s.e}</div><div class="sn">${s.name}</div><div class="sr">${s.role}</div></div>`).join('');}
function pick(id){CA=STAFF.find(s=>s.id===id);CH=[];document.querySelectorAll('.sc').forEach(x=>x.classList.remove('on'));document.getElementById('sc-'+id).classList.add('on');document.getElementById('cbox').style.display='block';document.getElementById('cav2').textContent=CA.e;document.getElementById('cav2').style.background=CA.c+'22';document.getElementById('cname').textContent=CA.name;document.getElementById('crole').textContent=CA.role;document.getElementById('cmsg').innerHTML=`<div class="msg a">Hi! I'm ${CA.name}, your ${CA.role} specialist. How can I help?</div>`;document.getElementById('cbox').scrollIntoView({behavior:'smooth'});}
async function send(){if(!CA)return;const inp=document.getElementById('cinp');const msg=inp.value.trim();if(!msg)return;inp.value='';const el=document.getElementById('cmsg');el.innerHTML+=`<div class="msg u">${msg}</div><div class="ld" id="ald"><div class="sp"></div> Thinking...</div>`;el.scrollTop=el.scrollHeight;try{const r=await fetch(API+'/api/ai/'+CA.id,{method:'POST',headers:{Authorization:'Bearer '+T,'Content-Type':'application/json'},body:JSON.stringify({message:msg,history:CH})});const d=await r.json();document.getElementById('ald')&&document.getElementById('ald').remove();const rep=d.response||'Try again.';CH.push({role:'user',content:msg},{role:'assistant',content:rep});el.innerHTML+=`<div class="msg a">${rep}</div>`;el.scrollTop=el.scrollHeight;}catch(e){document.getElementById('ald')&&document.getElementById('ald').remove();el.innerHTML+=`<div class="msg a">Error. Try again.</div>`;}}
async function loadDeals(f=''){try{const r=await fetch(API+'/api/deals'+(f?'?type='+f:''),{headers:{Authorization:'Bearer '+T}});const d=await r.json();const el=document.getElementById('deals');if(!d.length){el.innerHTML='<div class="es"><div style="font-size:2rem">🤝</div><p>No deals yet!</p></div>';return;}const bc={'Partnership':'rgba(0,229,255,0.15)','Investment':'rgba(159,107,255,0.15)','Acquisition':'rgba(255,45,120,0.15)','Franchise':'rgba(255,200,0,0.15)','Joint Venture':'rgba(0,255,150,0.15)'};const tc={'Partnership':'#00e5ff','Investment':'#9f6bff','Acquisition':'#ff2d78','Franchise':'#ffc800','Joint Venture':'#00ff96'};el.innerHTML=d.map(x=>`<div class="dc"><span class="db" style="background:${bc[x.deal_type]||'rgba(0,229,255,0.15)'};color:${tc[x.deal_type]||'#00e5ff'}">${x.deal_type||'Deal'}</span><div style="font-weight:700;margin-bottom:5px">${x.title}</div><div style="font-size:0.82rem;color:#8888aa;margin-bottom:6px">${x.description||''}</div><div style="font-size:0.72rem;color:#8888aa">By ${x.users&&x.users.business_name||'Business'} · ${ago(x.created_at)}</div></div>`).join('');}catch(e){}}
function filt(t,btn){DF=t;document.querySelectorAll('.dtb').forEach(b=>b.classList.remove('on'));btn.classList.add('on');loadDeals(t);}
function openDeal(){document.getElementById('dealov').classList.add('on');}
function closeDeal(){document.getElementById('dealov').classList.remove('on');}
async function postDeal(){const title=document.getElementById('dtitle').value.trim();const deal_type=document.getElementById('dtype').value;const description=document.getElementById('ddesc').value.trim();if(!title)return toast('Enter a title');try{const r=await fetch(API+'/api/deals',{method:'POST',headers:{Authorization:'Bearer '+T,'Content-Type':'application/json'},body:JSON.stringify({title,deal_type,description})});if(r.ok){closeDeal();toast('Deal posted!');loadDeals(DF);}}catch(e){toast('Error');}}
async function loadNet(){try{const r=await fetch(API+'/api/search',{headers:{Authorization:'Bearer '+T}});const d=await r.json();const el=document.getElementById('netlist');const f=d.filter(x=>x.id!==U.id);if(!f.length){el.innerHTML='<div class="es"><div style="font-size:2rem">🌐</div><p>No businesses yet!</p></div>';return;}el.innerHTML=f.map(u=>`<div class="uc"><div class="av" style="flex-shrink:0">${(u.business_name||'?')[0].toUpperCase()}</div><div class="ui"><strong>${u.business_name||'Business'}</strong><span>${u.industry||''}</span></div><button class="fb" onclick="follow('${u.id}',this)">Follow</button></div>`).join('');}catch(e){}}
async function follow(id,btn){try{const f=btn.classList.contains('on');await fetch(API+'/api/follow/'+id,{method:f?'DELETE':'POST',headers:{Authorization:'Bearer '+T}});btn.classList.toggle('on');btn.textContent=f?'Follow':'Following';toast(f?'Unfollowed':'Following!');}catch(e){}}
function srch(q){if(!q){loadNet();return;}fetch(API+'/api/search?q='+encodeURIComponent(q),{headers:{Authorization:'Bearer '+T}}).then(r=>r.json()).then(d=>{const el=document.getElementById('netlist');el.innerHTML=d.filter(x=>x.id!==U.id).map(u=>`<div class="uc"><div class="av" style="flex-shrink:0">${(u.business_name||'?')[0].toUpperCase()}</div><div class="ui"><strong>${u.business_name||'Business'}</strong><span>${u.industry||''}</span></div><button class="fb" onclick="follow('${u.id}',this)">Follow</button></div>`).join('');go('net');}).catch(()=>{});}
async function loadProfile(){try{const r=await fetch(API+'/api/users/'+U.id,{headers:{Authorization:'Bearer '+T}});const d=await r.json();document.getElementById('pposts').textContent=d.posts&&d.posts.length||0;document.getElementById('pfol').textContent=d.followers||0;document.getElementById('pfolg').textContent=d.following||0;}catch(e){}}
async function sub(pid){try{const r=await fetch(API+'/api/stripe/checkout',{method:'POST',headers:{Authorization:'Bearer '+T,'Content-Type':'application/json'},body:JSON.stringify({priceId:pid})});const d=await r.json();if(d.url)window.location.href=d.url;}catch(e){toast('Error');}}
function logout(){localStorage.removeItem('bf_token');localStorage.removeItem('bf_user');window.location.href='/';}
function ago(dt){const s=Math.floor((Date.now()-new Date(dt))/1000);if(s<60)return 'just now';if(s<3600)return Math.floor(s/60)+'m ago';if(s<86400)return Math.floor(s/3600)+'h ago';return Math.floor(s/86400)+'d ago';}
function toast(m){const t=document.getElementById('toast');t.textContent=m;t.classList.add('on');setTimeout(()=>t.classList.remove('on'),2500);}
init();
</script>
</body></html>
