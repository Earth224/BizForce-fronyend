<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>BizForce AI</title><style>*{margin:0;padding:0;box-sizing:border-box}body{background:#030308;color:#e8e8ff;font-family:system-ui;min-height:100vh}.topnav{position:fixed;top:0;left:0;right:0;height:60px;background:rgba(3,3,8,0.95);border-bottom:1px solid rgba(0,229,255,0.15);display:flex;align-items:center;padding:0 16px;gap:12px;z-index:50}.logo{font-size:1.1rem;font-weight:800;background:linear-gradient(135deg,#00e5ff,#9f6bff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}.search{flex:1;max-width:300px;background:rgba(255,255,255,0.05);border:1px solid rgba(0,229,255,0.15);border-radius:20px;padding:7px 14px;color:#e8e8ff;font-size:0.85rem;outline:none}.av{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,#00e5ff,#9f6bff);display:flex;align-items:center;justify-content:center;font-weight:700;color:#000;cursor:pointer;margin-left:auto;font-size:0.8rem}.main{padding:70px 16px 80px;max-width:640px;margin:0 auto}.page{display:none}.page.on{display:block}.bottomnav{position:fixed;bottom:0;left:0;right:0;height:62px;background:rgba(3,3,8,0.95);border-top:1px solid rgba(0,229,255,0.15);display:flex;align-items:center;justify-content:space-around;z-index:50}.nb{display:flex;flex-direction:column;align-items:center;gap:3px;background:none;border:none;color:#8888aa;cursor:pointer;padding:6px 12px;font-size:0.6rem;border-radius:10px}.nb.on{color:#00e5ff}.nb svg{width:20px;height:20px}.card{background:rgba(255,255,255,0.03);border:1px solid rgba(0,229,255,0.15);border-radius:14px;padding:16px;margin-bottom:12px}.sh{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}.sh h2{font-size:1rem;font-weight:700}.sbtn{padding:6px 12px;border-radius:16px;background:linear-gradient(135deg,#00e5ff,#9f6bff);border:none;color:#000;font-weight:700;font-size:0.75rem;cursor:pointer}.composer{display:flex;gap:10px;margin-bottom:16px}.composer textarea{flex:1;background:rgba(255,255,255,0.05);border:1px solid rgba(0,229,255,0.15);border-radius:10px;padding:10px;color:#e8e8ff;font-size:0.88rem;resize:none;outline:none;min-height:70px;font-family:inherit}.post{background:rgba(255,255,255,0.03);border:1px solid rgba(0,229,255,0.15);border-radius:14px;padding:14px;margin-bottom:10px}.ph{display:flex;align-items:center;gap:8px;margin-bottom:8px}.pm strong{font-size:0.85rem}.pm span{color:#8888aa;font-size:0.72rem;display:block}.pc{font-size:0.87rem;line-height:1.5}.pa{display:flex;gap:12px;margin-top:10px;padding-top:10px;border-top:1px solid rgba(0,229,255,0.1)}.pab{background:none;border:none;color:#8888aa;cursor:pointer;font-size:0.77rem}.pab:hover{color:#00e5ff}.sg{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:16px}.sc{background:rgba(255,255,255,0.03);border:1px solid rgba(0,229,255,0.15);border-radius:12px;padding:12px;text-align:center;cursor:pointer;transition:all 0.2s}.sc:hover,.sc.on{border-color:#00e5ff;background:rgba(0,229,255,0.05)}.se{width:40px;height:40px;border-radius:50%;margin:0 auto 6px;display:flex;align-items:center;justify-content:center;font-size:1.1rem}.sn{font-size:0.82rem;font-weight:700}.sr{font-size:0.68rem;color:#8888aa;margin-top:2px}.cb{background:rgba(255,255,255,0.03);border:1px solid rgba(0,229,255,0.15);border-radius:14px;overflow:hidden;margin-top:12px}.ch{padding:12px;border-bottom:1px solid rgba(0,229,255,0.15);display:flex;align-items:center;gap:8px}.cm{height:300px;overflow-y:auto;padding:12px;display:flex;flex-direction:column;gap:10px}.msg{max-width:78%;padding:9px 12px;border-radius:12px;font-size:0.85rem;line-height:1.5}.msg.u{background:linear-gradient(135deg,#00e5ff,#9f6bff);color:#000;align-self:flex-end}.msg.a{background:rgba(255,255,255,0.07);border:1px solid rgba(0,229,255,0.15);align-self:flex-start}.ci{padding:10px;border-top:1px solid rgba(0,229,255,0.15);display:flex;gap:8px}.ci input{flex:1;background:rgba(255,255,255,0.05);border:1px solid rgba(0,229,255,0.15);border-radius:18px;padding:9px 14px;color:#e8e8ff;font-size:0.87rem;outline:none}.ci input:focus{border-color:#00e5ff}.sendbtn{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#00e5ff,#9f6bff);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0}.dt{display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap}.dtb{padding:5px 12px;border-radius:16px;border:1px solid rgba(0,229,255,0.15);background:transparent;color:#8888aa;cursor:pointer;font-size:0.77rem}.dtb.on{background:linear-gradient(135deg,#00e5ff,#9f6bff);color:#000;font-weight:700;border-color:transparent}.dc{background:rgba(255,255,255,0.03);border:1px solid rgba(0,229,255,0.15);border-radius:12px;padding:14px;margin-bottom:10px}.db{display:inline-block;padding:2px 8px;border-radius:12px;font-size:0.68rem;font-weight:700;text-transform:uppercase;margin-bottom:6px}.uc{background:rgba(255,255,255,0.03);border:1px solid rgba(0,229,255,0.15);border-radius:12px;padding:14px;margin-bottom:10px;display:flex;align-items:center;gap:10px}.ui{flex:1}.ui strong{font-size:0.87rem}.ui span{color:#8888aa;font-size:0.73rem;display:block}.fb{padding:6px 14px;border-radius:16px;border:1px solid #00e5ff;background:transparent;color:#00e5ff;cursor:pointer;font-size:0.77rem;font-weight:700}.fb:hover,.fb.on{background:#00e5ff;color:#000}.ph2{text-align:center;padding:16px 0}.pa2{width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,#00e5ff,#9f6bff);display:flex;align-items:center;justify-content:center;font-size:1.8rem;font-weight:700;color:#000;margin:0 auto 10px}.ps{display:flex;justify-content:center;gap:28px;margin:12px 0}.pst strong{display:block;font-size:1.1rem;text-align:center}.pst span{color:#8888aa;font-size:0.72rem}.pg{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:14px 0}.pc2{background:rgba(255,255,255,0.03);border:1px solid rgba(0,229,255,0.15);border-radius:14px;padding:16px 10px;text-align:center}.pc2.feat{border-color:#00e5ff;background:rgba(0,229,255,0.05)}.pc2 h3{font-size:0.82rem;color:#8888aa;margin-bottom:6px}.pp{font-size:1.4rem;font-weight:800;margin-bottom:3px}.pp span{font-size:0.75rem;font-weight:400;color:#8888aa}.pf{font-size:0.7rem;color:#8888aa;margin:8px 0;line-height:1.7}.pb{width:100%;padding:8px;border-radius:8px;border:1px solid #00e5ff;background:transparent;color:#00e5ff;cursor:pointer;font-weight:700;font-size:0.75rem}.pb:hover,.pc2.feat .pb{background:#00e5ff;color:#000}.ld{display:flex;align-items:center;gap:6px;color:#8888aa;font-size:0.82rem;padding:10px}.sp{width:14px;height:14px;border:2px solid rgba(0,229,255,0.2);border-top-color:#00e5ff;border-radius:50%;animation:spin 0.8s linear infinite}@keyframes spin{to{transform:rotate(360deg)}}.es{text-align:center;padding:32px 16px;color:#8888aa}.es p{margin-top:6px;font-size:0.82rem}.toast{position:fixed;bottom:72px;left:50%;transform:translateX(-50%);background:rgba(0,229,255,0.15);border:1px solid #00e5ff;color:#00e5ff;padding:8px 18px;border-radius:16px;font-size:0.82rem;font-weight:600;z-index:300;opacity:0;transition:opacity 0.3s;pointer-events:none}.toast.on{opacity:1}.ov{position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:200;display:none;align-items:center;justify-content:center;padding:16px}.ov.on{display:flex}.mod{background:#080812;border:1px solid rgba(0,229,255,0.15);border-radius:18px;padding:24px;width:100%;max-width:440px}.mod h3{margin-bottom:16px;font-size:1rem}label{display:block;color:#8888aa;font-size:0.75rem;text-transform:uppercase;margin-bottom:5px;margin-top:12px}input,select,textarea{width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(0,229,255,0.15);border-radius:8px;padding:10px 12px;color:#e8e8ff;font-size:0.88rem;outline:none;font-family:inherit}input:focus,select:focus,textarea:focus{border-color:#00e5ff}select option{background:#0d0d1a}.ma{display:flex;gap:8px;justify-content:flex-end;margin-top:16px}.cnc{padding:9px 18px;border-radius:8px;border:1px solid rgba(0,229,255,0.15);background:transparent;color:#8888aa;cursor:pointer}</style></head><body>
<div style="position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0;overflow:hidden"><div style="position:absolute;width:400px;height:400px;background:#00e5ff;border-radius:50%;filter:blur(80px);opacity:0.08;top:-100px;left:-100px;animation:float 20s infinite ease-in-out"></div><div style="position:absolute;width:350px;height:350px;background:#9f6bff;border-radius:50%;filter:blur(80px);opacity:0.08;top:30%;right:-100px;animation:float 20s infinite ease-in-out;animation-delay:-7s"></div><div style="position:absolute;width:280px;height:280px;background:#ff2d78;border-radius:50%;filter:blur(80px);opacity:0.08;bottom:-100px;left:30%;animation:float 20s infinite ease-in-out;animation-delay:-14s"></div></div>
<style>@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-20px)}}</style>
